{
  "name": "portfolio",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "prepare": "husky install",
    "pre-commit": "lint-staged",
    "pre-push": "npm run lint",
    "commit-msg": "commitlint",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "analyze": "cross-env ANALYZE=true next build",
    "translations:lint": "ts-node -r tsconfig-paths/register src/translations --lint",
    "translations:compile": "ts-node -r tsconfig-paths/register src/translations --compile",
    "lint": "tsc && eslint \"**/*.{js,mjs,ts,tsx}\" && prettier --check \"**/*.{js,mjs,ts,tsx,json,yml}\"",
    "format": "tsc && eslint \"**/*.{js,mjs,ts,tsx}\" --fix && prettier --write --loglevel warn \"**/*.{js,mjs,ts,tsx,json,yml}\" && npm run translations:lint",
    "clean": "del-cli tsconfig.tsbuildinfo .next .swc public/bootstrap.js public/locales"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/material": "^7.3.1",
    "@mui/utils": "^7.3.1",
    "@next/bundle-analyzer": "^15.5.2",
    "@next/env": "^15.5.2",
    "@plaiceholder/next": "^3.0.0",
    "@svgr/webpack": "^8.1.0",
    "@types/glob": "^9.0.0",
    "@types/mkdirp": "^2.0.0",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "@types/yargs": "^17.0.33",
    "@typescript-eslint/eslint-plugin": "^8.41.0",
    "darkmode-js": "^1.5.7",
    "flatten-anything": "^4.0.2",
    "framer-motion": "^12.23.12",
    "glob": "^11.0.3",
    "husky": "^9.1.7",
    "i18next": "^25.4.2",
    "immer": "^10.1.1",
    "lint-staged": "^16.1.5",
    "material-ui-popup-state": "^5.3.6",
    "merge-anything": "^6.0.6",
    "mkdirp": "^3.0.1",
    "next": "^15.5.2",
    "next-i18next": "^15.4.2",
    "polished": "^4.3.1",
    "prettier": "^3.6.2",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-i18next": "^15.7.2",
    "react-query": "^3.39.3",
    "react-resize-detector": "^12.3.0",
    "sharp": "^0.34.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2",
    "yargs": "^18.0.0"
  },
  "lint-staged": {
    "**/*.{js,mjs,ts,tsx}": [
      "eslint --fix"
    ],
    "**/*.{js,mjs,ts,tsx,json,yml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@contentful/rich-text-react-renderer": "^16.1.0",
    "@types/node": "24.3.0",
    "eslint": "^9.34.0",
    "eslint-config-next": "^15.5.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-consistent-default-export-name": "^0.0.15",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsdoc": "^54.1.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prefer-arrow": "^1.2.3",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-sort-exports": "^0.9.1",
    "eslint-plugin-unicorn": "^60.0.0",
    "eslint-plugin-unused-imports": "^4.2.0"
  },
  "browser": {
    "fs": false,
    "path": false,
    "os": false
  }
}
